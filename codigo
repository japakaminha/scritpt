local function _tryScorePlayer(player, maxDist)
    if player == LocalPlayer then return nil end
    
    local char = player.Character
    if not char or not char.Parent then return nil end
    
    local cc = _getCharCache(char)
    local hum = cc and cc.hum
    
    if not hum or hum.Health <= 0 then return nil end
    
    local root = cc and cc.root
    if not root or not root.Parent then return nil end
    
    if Config.Whitelist[player.UserId] then return nil end
    
    if Config.TeamCheck then
        local myTeam = LocalPlayer.Team
        if myTeam and player.Team == myTeam then return nil end
    end
    
    local camPos = Camera.CFrame.Position
    local tarPos = root.Position
    local dx = camPos.X - tarPos.X
    local dy = camPos.Y - tarPos.Y
    local dz = camPos.Z - tarPos.Z
    local dist2 = dx * dx + dy * dy + dz * dz
    
    if dist2 > maxDist * maxDist then return nil end
    if dist2 < MIN_TARGET_DIST2 then return nil end
    
    local aimPart = cc and cc.Head
    if not aimPart or not aimPart.Parent then return nil end
    
    local camCF = Camera.CFrame
    local toTarget = (aimPart.Position - camCF.Position).Unit
    local lookDir = camCF.LookVector
    local angle = math.acos(clamp(toTarget:Dot(lookDir), -1, 1))
    local angleDeg = deg(angle)
    
    local effFov = Config.FOV or 60
    if angleDeg > effFov then return nil end
    
    local wF = _cachedWFOV
    local wD = _cachedWDist
    local wH = _cachedWHP
    local invTotal = _cachedWInvTotal
    
    local fovScore = 1 - (angleDeg / effFov)
    local distScore = 1 - sqrt(dist2) / (maxDist or 100)
    local hpScore = hum.Health / max(hum.MaxHealth, 1)
    
    local score = (fovScore * wF + distScore * wD + hpScore * wH) * invTotal
    
    return score, player, aimPart, root, { inVehicle = isInVehicle(char) }
end

local function findBestTarget()
    if bestTarget and bestTarget.Parent then
        local cc = _getCharCache(bestTarget)
        local hum = cc and cc.hum
        if hum and hum.Health > 0 and bestAimPart and bestAimPart.Parent then
            return bestTarget, bestAimPart, bestTargetRoot, bestTargetState
        end
    end
    
    local bestScore = -huge
    local bestPlayer, bestPart, bestRoot, bestState = nil, nil, nil, nil
    
    for _, player in ipairs(Players:GetPlayers()) do
        local score, pOut, partOut, rootOut, stateOut = _tryScorePlayer(player, Config.MaxDistance or 100)
        
        if score and score > bestScore then
            bestScore = score
            bestPlayer = pOut
            bestPart = partOut
            bestRoot = rootOut
            bestState = stateOut
        end
    end
    
    return bestPlayer, bestPart, bestRoot, bestState
end

local function applyAim(targetCF, smooth)
    if not isCameraModifiable() then return end
    
    local dt = 0.016
    local currentCF = Camera.CFrame
    
    if not targetCF then return end
    
    local speed = _cachedSmoothSpeed * dt
    speed = clamp(speed, 0, 1)
    
    local newCF = currentCF:Lerp(targetCF, speed)
    Camera.CFrame = newCF
end

