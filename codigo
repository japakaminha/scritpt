local NOTIF_INTERVAL=0.35; local NOTIF_MAX_QUEUE=10; local NOTIF_MAX_SCREEN=5
local notifQueue={}; local notifHead=1; local notifTail=0; local activeNotifCount=0; local notifOrderCount=0
local NotifContainer=nil; local _notifDebounce={}; local NOTIF_DEBOUNCE_T=0.4
local _notifDebouncePurgeT=0  -- FIX: purge periódico para evitar acúmulo infinito de chaves
local NOTIF_COLORS={info=Color3.fromRGB(80,120,220),warn=Color3.fromRGB(220,180,40),error=Color3.fromRGB(220,60,60),success=Color3.fromRGB(60,200,100)}

local function notify(msg,nType,duration)
    if not isRunning then return end; msg=tostring(msg or "")
    if (notifTail-notifHead+1)>=NOTIF_MAX_QUEUE then return end
    nType=nType or "info"
    if nType~="error" and nType~="success" then
        local debounceKey=nType..":"..msg; local now=tick()
        -- FIX: purge entradas velhas a cada 30s para evitar leak de memória
        if now-_notifDebouncePurgeT>30 then
            _notifDebouncePurgeT=now
            for k,t in pairs(_notifDebounce) do if now-t>NOTIF_DEBOUNCE_T*2 then _notifDebounce[k]=nil end end
        end
        local last=_notifDebounce[debounceKey]
        if last and (now-last)<NOTIF_DEBOUNCE_T then return end; _notifDebounce[debounceKey]=now
    end
    if notifTail>=notifHead then local last=notifQueue[notifTail]; if last and last.msg==msg and last.nType==nType then last.count=last.count+1; return end end
    notifTail=notifTail+1; notifQueue[notifTail]={msg=msg,nType=nType,duration=duration or 3.5,count=1}
end

task.spawn(function()
    while isRunning do
        task.wait(NOTIF_INTERVAL)
        if not NotifContainer then continue end
        if notifHead>notifTail then continue end
        if activeNotifCount>=NOTIF_MAX_SCREEN then continue end
        local item=notifQueue[notifHead]; notifQueue[notifHead]=nil; notifHead=notifHead+1
        if notifHead>notifTail then notifHead=1; notifTail=0 end  -- FIX: não iterar de head a tail ao resetar (já nil-ados)
        local displayMsg=item.msg; if item.count and item.count>1 then displayMsg=item.msg.." (x"..item.count..")" end
        activeNotifCount=activeNotifCount+1; notifOrderCount=notifOrderCount+1
        local ok=pcall(function()
            local fr=Instance.new("Frame"); fr.Size=UDim2.new(1,0,0,0); fr.BackgroundColor3=Color3.fromRGB(20,20,30)
            fr.BorderSizePixel=0; fr.ClipsDescendants=true; fr.LayoutOrder=notifOrderCount; fr.Parent=NotifContainer
            Instance.new("UICorner",fr).CornerRadius=UDim.new(0,6)
            local bar=Instance.new("Frame",fr); bar.Size=UDim2.new(0,4,1,0); bar.BorderSizePixel=0
            bar.BackgroundColor3=NOTIF_COLORS[item.nType] or NOTIF_COLORS.info
            Instance.new("UICorner",bar).CornerRadius=UDim.new(0,6)
            local lbl=Instance.new("TextLabel",fr); lbl.Size=UDim2.new(1,-16,1,0); lbl.Position=UDim2.new(0,12,0,0)
            lbl.BackgroundTransparency=1; lbl.TextColor3=Color3.fromRGB(220,220,230); lbl.TextSize=13
