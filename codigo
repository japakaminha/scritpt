-- Off-Screen Indicator — seta apontando pro alvo fora da tela
local _osArrow=makeDrawing("Triangle",{Filled=true,Color=Color3.fromRGB(255,80,80),Thickness=1})
local _osArrowOutline=makeDrawing("Triangle",{Filled=false,Color=Color3.fromRGB(0,0,0),Thickness=2})
local _lastOSVisible=false

local function _updateOffScreen(camCF,vpX,vpY)
    if not HAS_DRAWING or not Config.OffScreenEnabled or not bestTarget or not bestAimPart then
        if _lastOSVisible then _osArrow.Visible=false; _osArrowOutline.Visible=false; _lastOSVisible=false end; return
    end
    local spX,spY,spZ,onScreen=getVPPoint(bestAimPart)
    if onScreen and spZ>0 then
        if _lastOSVisible then _osArrow.Visible=false; _osArrowOutline.Visible=false; _lastOSVisible=false end; return
    end
    local camPos=camCF.Position; local tarPos=bestAimPart.Position
    local dx=tarPos.X-camPos.X; local dy=tarPos.Y-camPos.Y; local dz=tarPos.Z-camPos.Z
    local tarWorld=Vector3.new(dx,dy,dz)
    local right=camCF.RightVector; local up=camCF.UpVector
    local screenX=tarWorld:Dot(right); local screenY=-tarWorld:Dot(up)
    local mag=sqrt(screenX*screenX+screenY*screenY); if mag<0.001 then
        if _lastOSVisible then _osArrow.Visible=false; _osArrowOutline.Visible=false; _lastOSVisible=false end; return  -- FIX: esconder seta se vetores degenerados
    end
    local nx=screenX/mag; local ny=screenY/mag
    local margin=40; local cx=vpX*0.5; local cy=vpY*0.5
    local halfX=cx-margin; local halfY=cy-margin
    local tx,ty
    if abs(nx)*halfY>abs(ny)*halfX then local s=halfX/abs(nx); tx=cx+nx*s; ty=cy+ny*s
    else local s=halfY/abs(ny); tx=cx+nx*s; ty=cy+ny*s end
    tx=clamp(tx,margin,vpX-margin); ty=clamp(ty,margin,vpY-margin)
    -- usar cor do ESP do alvo
    local arrowColor=_C_LOCK_ESP  -- alvo travado usa cor de lock
    local vcached=_visCache[bestTarget]; local isVisible=vcached and vcached.vis or false
    if not isVisible then arrowColor=Config.ESPWallColor end
    local sz=Config.OffScreenSize; local angle=math.atan2(ny,nx)
    local cosA=cos(angle); local sinA=sin(angle)
    local function rot(px,py) return tx+px*cosA-py*sinA,ty+px*sinA+py*cosA end
    local ax,ay=rot(sz,0); local bx,by=rot(-sz*0.5,sz*0.5); local cx2,cy2=rot(-sz*0.5,-sz*0.5)
    local va=Vector2.new(ax,ay); local vb=Vector2.new(bx,by); local vc=Vector2.new(cx2,cy2)
    _osArrow.PointA=va; _osArrow.PointB=vb; _osArrow.PointC=vc
    _osArrow.Color=arrowColor; _osArrow.Visible=true
    _osArrowOutline.PointA=va; _osArrowOutline.PointB=vb; _osArrowOutline.PointC=vc; _osArrowOutline.Visible=true
    _lastOSVisible=true
end

