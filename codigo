function Lib._fovCircle(targetDist)
    if not HAS_DRAWING then return end
    local vp=Camera.ViewportSize; local vpX=vp.X; local vpY=vp.Y
    local fovDisplay=Config.FOV
    if targetDist then
        if Config.FOVSyncVisual then fovDisplay=Lib._getEffFov(targetDist,bestTargetState)
        else local _fRange=Config.FOVMaxDist-Config.FOVMinDist; local t=_fRange~=0 and clamp((targetDist-Config.FOVMinDist)/_fRange,0,1) or 0; fovDisplay=max(Config.FOV*(1-_fovCurveFactor(t)*0.75),5) end
    end
    local aspectRatio=vpX/vpY
    if fovDisplay~=_lastFovDisplay or vpY~=_lastFovCircleVpY or vpX~=_lastFovCircleVpX or aspectRatio~=_lastAspectRatio then
        _lastFovDisplay=fovDisplay; _lastFovCircleVpY=vpY; _lastFovCircleVpX=vpX; _lastAspectRatio=aspectRatio
        _cachedFovRadiusX,_cachedFovRadiusY=_calcFovRadii(fovDisplay,vpX,vpY)
        -- FIX: notificar resolução só quando viewport realmente mudou (não a cada recalc de FOV)
        if vpX~=_lastNotifVpX or vpY~=_lastNotifVpY then
            _lastNotifVpX=vpX; _lastNotifVpY=vpY
            local aspectName,ratio=_detectAspectName(vpX,vpY)
            if aspectName~=_lastNotifiedAspect then _lastNotifiedAspect=aspectName; notify(sfmt("Resolução: %dx%d → %s (%.3f:1)",vpX,vpY,aspectName,ratio),"info",5) end
        end
    end
    local cx=vpX*0.5; local cy=vpY*0.5; local vis=Config.AimbotEnabled and Config.ShowFOV
    local rx=_cachedFovRadiusX; local ry=_cachedFovRadiusY
    if _fovFullScreen then
        local margin=4
        if vis~=_fovDirty_vis or cx~=_fovDirty_cx or cy~=_fovDirty_cy then
            _fovDirty_vis=vis; _fovDirty_rx=-1; _fovDirty_ry=-1; _fovDirty_cx=cx; _fovDirty_cy=cy
            local lines=_fovLines; local seg=FOV_ELLIPSE_SEGS/4
            local x1,y1,x2,y2=margin,margin,vpX-margin,vpY-margin
            for i=0,FOV_ELLIPSE_SEGS-1 do
                local side=floor(i/seg); local t_=(i%seg)/seg; local t2=(i+1)%FOV_ELLIPSE_SEGS; local side2=floor(t2/seg); local t2_=(t2%seg)/seg
                local function pt(s,frac) if s==0 then return x1+(x2-x1)*frac,y1 elseif s==1 then return x2,y1+(y2-y1)*frac elseif s==2 then return x2-(x2-x1)*frac,y2 else return x1,y2-(y2-y1)*frac end end
                local fx,fy=pt(side,t_); local tx_,ty_=pt(side2,t2_)
                local l=lines[i+1]; l.From=Vector2.new(fx,fy); l.To=Vector2.new(tx_,ty_); l.Visible=vis
            end
        end
        fovCircle.Visible=vis; return
    end
    if vis~=_fovDirty_vis or rx~=_fovDirty_rx or ry~=_fovDirty_ry or cx~=_fovDirty_cx or cy~=_fovDirty_cy then
        _fovDirty_vis=vis; _fovDirty_rx=rx; _fovDirty_ry=ry; _fovDirty_cx=cx; _fovDirty_cy=cy
        local precos=_fovPreCos; local presin=_fovPreSin; local lines=_fovLines
        for i=0,FOV_ELLIPSE_SEGS-1 do
            local l=lines[i+1]; l.From=Vector2.new(cx+precos[i]*rx,cy+presin[i]*ry); l.To=Vector2.new(cx+precos[i+1]*rx,cy+presin[i+1]*ry); l.Visible=vis
        end
        fovCircle.Visible=vis
    end
end

