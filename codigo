    local char=LocalPlayer.Character; if not char then _peekReset(); return end
    local hrp=char:FindFirstChild("HumanoidRootPart"); if not hrp then _peekReset(); return end
    -- FIX: pre-check de variáveis de peek antes de usá-las
    if not _peekOriginCF or not _peekTargetPos then _peekReset(); return end
    local peekSpeed=Config.AutoPeekSpeed*dt

    if _peekState=="peeking" then
