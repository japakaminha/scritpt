    local hpNorm=maxHealth>0 and (1-health/maxHealth) or 0
    local score=(_cachedWFOV*fovNorm+_cachedWDist*distNorm+_cachedWHP*hpNorm)*_cachedWInvTotal
    if Config.PriorityList[player.UserId] then score=score*0.1 end
