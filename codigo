local function _inputMatch(input, bind)
    if not bind then return false end
    if bind.ktype == "key" then
        return input.KeyCode == bind.value
    elseif bind.ktype == "mouse" then
        return input.UserInputType == bind.value
    end
    return false
end

local panicHoldStart = nil

Lib.Connections.InputBegan = UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    local aimBind = Config.Keybinds.AimbotKey
    if aimBind and _inputMatch(input, aimBind) then
        if Config.AimbotMode == "Toggle" then
            Config.AimbotEnabled = not Config.AimbotEnabled
            notify("Aimbot: " .. (Config.AimbotEnabled and "ON" or "OFF"), 
