    Config.ActiveProfile = profileName
    configDirty = true
    notify("Perfil '"..profileName.."' salvo", "success", 2)
    saveConfig()
end

Lib._loadProfile = function(profileName)
    if not profileName then return end
    local prof = Config.Profiles[profileName]
    if not prof then return end
    
    local loaded = _deserializeConfig(prof)
    for k, v in pairs(loaded) do
        Config[k] = v
    end
    
    Config.ActiveProfile = profileName
    notify("Perfil '"..profileName.."' carregado", "success", 2)
end

Lib._deleteProfile = function(profileName)
    Config.Profiles[profileName] = nil
    if Config.ActiveProfile == profileName then
        Config.ActiveProfile = nil
    end
    configDirty = true
    saveConfig()
    notify("Perfil '"..profileName.."' deletado", "info", 2)
end

