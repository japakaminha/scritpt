local function log(msg,level)
    level=level or LogLevel.INFO; if level<LogLevel.WARN and not Config.DebugMode then return end
    local prefix=level==LogLevel.ERROR and "[ERRO] " or level==LogLevel.WARN and "[AVISO] " or "[INFO] "
    local ntype=level==LogLevel.ERROR and "error" or level==LogLevel.WARN and "warn" or "info"
    notify(prefix..tostring(msg or ""),ntype)
end
