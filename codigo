local NOTIF_INTERVAL=0.35
local NOTIF_MAX_QUEUE=10
local NOTIF_MAX_SCREEN=5
local NOTIF_DEBOUNCE_MAX_ENTRIES=500
local NOTIF_DEBOUNCE_T=0.4

local notifQueue={}
local notifHead=1
local notifTail=0
local activeNotifCount=0
local notifOrderCount=0
local NotifContainer=nil

local _notifDebounce={}
local _notifDebouncePurgeT=0
local _notifDebounceEntryCount=0

local NOTIF_COLORS={
    info=Color3.fromRGB(80,120,220),
    warn=Color3.fromRGB(220,180,40),
    error=Color3.fromRGB(220,60,60),
    success=Color3.fromRGB(60,200,100),
}

local function notify(msg, nType, duration)
    if not isRunning then return end
    
    msg = tostring(msg or "")
    
    if (notifTail - notifHead + 1) >= NOTIF_MAX_QUEUE then 
        return
    end
    
    nType = nType or "info"
    
    if nType ~= "error" and nType ~= "success" then
        local now = tick()
        
        if _notifDebounceEntryCount > NOTIF_DEBOUNCE_MAX_ENTRIES or now - _notifDebouncePurgeT > 20 then
            _notifDebouncePurgeT = now
            _notifDebounceEntryCount = 0
            for k, t in pairs(_notifDebounce) do
                if now - t > NOTIF_DEBOUNCE_T * 2 then
                    _notifDebounce[k] = nil
                else
                    _notifDebounceEntryCount = _notifDebounceEntryCount + 1
                end
            end
        end
        
        local debounceKey = nType .. ":" .. msg
        local lastTime = _notifDebounce[debounceKey]
        
        if lastTime and (now - lastTime) < NOTIF_DEBOUNCE_T then 
            return
        end
        
        if not _notifDebounce[debounceKey] then 
            _notifDebounceEntryCount = _notifDebounceEntryCount + 1 
        end
        _notifDebounce[debounceKey] = now
    end
    
    if notifTail >= notifHead then
        local lastNotif = notifQueue[notifTail]
        if lastNotif and lastNotif.msg == msg and lastNotif.nType == nType then
            lastNotif.count = lastNotif.count + 1
            return
        end
    end
    
    notifTail = notifTail + 1
    notifQueue[notifTail] = {
        msg = msg,
        nType = nType,
        duration = duration or 3.5,
        count = 1
    }
end

task.spawn(function()
    while isRunning do
        task.wait(NOTIF_INTERVAL)
        
        if not NotifContainer then continue end
        
        if notifHead > notifTail then continue end
        
        if activeNotifCount >= NOTIF_MAX_SCREEN then continue end
        
        local item = notifQueue[notifHead]
        notifQueue[notifHead] = nil
        notifHead = notifHead + 1
        
        if notifHead > notifTail then
            for i = notifHead, notifTail do notifQueue[i] = nil end
            notifHead = 1
            notifTail = 0
        end
        
        local displayMsg = item.msg
        if item.count and item.count > 1 then
            displayMsg = item.msg .. " (x" .. item.count .. ")"
        end
        
        activeNotifCount = activeNotifCount + 1
        notifOrderCount = notifOrderCount + 1
        
        local ok = pcall(function()
            local fr = Instance.new("Frame")
