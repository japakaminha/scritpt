local panicTimer=0
Lib.Connections.KeybindMain=UserInputService.InputBegan:Connect(function(input,gp)
    local kb=Config.Keybinds
    if Lib._inputMatch(input,kb.MenuOpen) then if isMenuOpen then Lib._closeMenu() else Lib._openMenu() end; return end
    if gp then return end
    -- Flick: ativado pela FlickKey (padrão Mouse1), independente do aimbot
    if Config.FlickEnabled and _flickState=="idle" and Lib._inputMatch(input,kb.FlickKey) then
        local camCF=Camera.CFrame; local vp=Camera.ViewportSize
        _flickStart(camCF,vp.X,vp.Y)
        if _flickState~="idle" then return end  -- consumir input só se flick iniciou (havia alvo)
    end
    if Lib._inputMatch(input,kb.AimbotKey) then
        if Config.AimbotMode=="Toggle" then Config.AimbotEnabled=not Config.AimbotEnabled; notify("Aimbot: "..(Config.AimbotEnabled and "ON" or "OFF"),Config.AimbotEnabled and "success" or "info"); _fovDirty_vis=nil; Lib._fovCircle(); Lib._statusDot()
        else isHoldingAim=true; Config.AimbotEnabled=true; _fovDirty_vis=nil; Lib._fovCircle(); Lib._statusDot(); notify("Aimbot Hold: segurando "..Lib._bindName(kb.AimbotKey),"info",1.5) end
    elseif Lib._inputMatch(input,kb.ESPKey) then Config.ESPEnabled=not Config.ESPEnabled; _updateESPAnyActive(); notify("ESP: "..(Config.ESPEnabled and "ON" or "OFF"),Config.ESPEnabled and "success" or "info"); Lib._statusDot()
    elseif Lib._inputMatch(input,kb.ReleaseLock) then if bestTarget then bestTarget=nil; bestAimPart=nil; bestTargetRoot=nil; _bestTargetLockStart=0; notify("Lock liberado manualmente","info",2) end
    elseif Config.AutoPeekEnabled and Lib._inputMatch(input,kb.PeekKey) then _peekStart()
    elseif Lib._inputMatch(input,kb.Panic) then panicTimer=tick() end
end)
Lib.Connections.KeybindEnd=UserInputService.InputEnded:Connect(function(input)
    local kb=Config.Keybinds
    if Config.AimbotMode=="Hold" and Lib._inputMatch(input,kb.AimbotKey) then
        isHoldingAim=false; Config.AimbotEnabled=false; bestAimPart=nil
