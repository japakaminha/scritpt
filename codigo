    if Config.SpringSmoothing then
        local damping=max(Config.SpringDamping*0.01,0.001); local omega=_cachedSmoothSpeed*damping; local k1=2*omega; local k2=omega*omega  -- FIX: damping nunca zero
        local ex=tarX-curLook.X; local ey=tarY-curLook.Y; local ez=tarZ-curLook.Z
        _springVelX=_springVelX+(k2*ex-k1*_springVelX)*dt; _springVelY=_springVelY+(k2*ey-k1*_springVelY)*dt; _springVelZ=_springVelZ+(k2*ez-k1*_springVelZ)*dt
        lx=curLook.X+_springVelX*dt; ly=curLook.Y+_springVelY*dt; lz=curLook.Z+_springVelZ*dt
    elseif Config.MagnetismEnabled then
        local dot=clamp(curLook.X*tarX+curLook.Y*tarY+curLook.Z*tarZ,-1,1); local angleFrac=(1-dot)*0.5
        -- FIX: cap 0.6→0.95 para permitir snap rápido quando Smooth alto
        local strength=(Config.MagnetismStrength*0.01)*(1-angleFrac); local t=clamp(strength*_cachedSmoothSpeed*dt,0,0.95)
        lx=curLook.X+(tarX-curLook.X)*t; ly=curLook.Y+(tarY-curLook.Y)*t; lz=curLook.Z+(tarZ-curLook.Z)*t
    else
        local t=1-exp(-_cachedSmoothSpeed*dt); lx=curLook.X+(tarX-curLook.X)*t; ly=curLook.Y+(tarY-curLook.Y)*t; lz=curLook.Z+(tarZ-curLook.Z)*t
    end
    local lmag=sqrt(lx*lx+ly*ly+lz*lz); if lmag<1e-6 then return end
    lx=lx/lmag; ly=ly/lmag; lz=lz/lmag; local newLook=Vector3.new(lx,ly,lz)
    if Config.MaxAngularSpeed<3600 then
        local dotVal=clamp(curLook:Dot(newLook),-1,1); local angleDeg=deg(acos(dotVal)); local maxAngle=Config.MaxAngularSpeed*dt
        if angleDeg>maxAngle and maxAngle>0 then
            local tLimited=(maxAngle/angleDeg); local llx=curLook.X+(lx-curLook.X)*tLimited; local lly=curLook.Y+(ly-curLook.Y)*tLimited; local llz=curLook.Z+(lz-curLook.Z)*tLimited
            local llmag=sqrt(llx*llx+lly*lly+llz*llz); if llmag<1e-6 then return end; newLook=Vector3.new(llx/llmag,lly/llmag,llz/llmag)
        end
    end
    local upVec=camCF.UpVector; local dot=newLook:Dot(upVec)
    if dot>0.9999 or dot<-0.9999 then Camera.CFrame=CFrame.lookAt(camPos_,camPos_+newLook)
    else Camera.CFrame=CFrame.lookAt(camPos_,camPos_+newLook,upVec) end
end

local _cachedAimFovR=0; local _lastAimFov=-1; local _lastAimVpY=-1
local _bestTargetLastLoS=0; local _bestTargetLockStart=0; local _cachedFovR2=0
local _cachedMaxDist2=Config.MaxDistance*Config.MaxDistance; local _cachedThreshR=0; local _cachedAspectRatio=1
local _lastMaxDist=Config.MaxDistance; local _lastLockThresh=-1; local _lastThreshVpY=-1; local _lastAspectVpX=-1; local _lastAspectVpY=-1

local function _tryScorePlayer(player,camCF,camPos_,vpHalfX,vpHalfY,fovR2,fovR,maxDist2,threshR,nowTick,aspectRatio,lockAge,inLockMin)
    if not player or player==false or not player.Parent then return end
    if Config.Whitelist[player.UserId] then return end
    local char=player.Character; if not char then return end
    local cc=_getCharCache(char); if not cc then return end; local hum=cc.hum; if not hum then return end
    local health=hum.Health; local maxHealth=hum.MaxHealth; if health<=0 then return end
    if Config.TeamCheck and player.Team==LocalPlayer.Team then return end
    local root=cc.root; if not root then return end
    local rp=root.Position; local dx3=camPos_.X-rp.X; local dy3=camPos_.Y-rp.Y; local dz3=camPos_.Z-rp.Z
    local dist3d2=dx3*dx3+dy3*dy3+dz3*dz3; if dist3d2>maxDist2 then return end; local dist3d=sqrt(dist3d2)
    local aimPart=_getHitboxPart(char,cc); if not aimPart then return end
    local spX,spY,spZ,onScreen=getVPPoint(aimPart); if not onScreen or spZ<=0 then return end
    local dx=(spX-vpHalfX)/aspectRatio; local dy=spY-vpHalfY; local d2d2=dx*dx+dy*dy
    if d2d2>fovR2 then return end; local d2d=sqrt(d2d2)
