local function makeDrawing(dtype, props, isPoolDrawing)
    if not HAS_DRAWING then
        return makeDummyDrawing()
    end
    
    local ok, d = pcall(function() return Drawing.new(dtype) end)
    if not ok or not d then
        return makeDummyDrawing()
    end
    
    d.Visible = false
    
    if props then
        pcall(function()
            for k, v in pairs(props) do
                d[k] = v
            end
        end)
    end
    
    if isPoolDrawing then
        Lib.AllPoolDrawings[#Lib.AllPoolDrawings + 1] = d
    else
        Lib.Drawings[#Lib.Drawings + 1] = d
    end
    
    return d
end

local function initDrawingPool(pool, count, dtype, props)
    for _ = 1, count do
        pool[#pool + 1] = makeDrawing(dtype, props, true)
    end
end

