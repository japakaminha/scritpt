local _ASPECT_TABLE={{1.0,0.03,"1:1"},{1.25,0.03,"5:4"},{1.3333,0.025,"4:3"},{1.6,0.025,"16:10"},{1.7778,0.025,"16:9"},{1.8962,0.030,"17:9"},{2.0,0.03,"18:9 / 2:1"},{2.111,0.03,"19:9"},{2.333,0.04,"21:9"},{2.667,0.05,"24:9"},{3.556,0.07,"32:9"}}
_detectAspectName=function(vpX,vpY)
    local r=vpX/vpY; local bestName,bestDiff=nil,huge
    for _,entry in ipairs(_ASPECT_TABLE) do local diff=abs(r-entry[1]); if diff<entry[2] and diff<bestDiff then bestDiff=diff; bestName=entry[3] end end
    if not bestName then bestName=sfmt("%.2f:1 (custom)",r) end; return bestName,r
end

local _fovFullScreen=false
local function _calcFovRadii(fovDeg,vpX,vpY)
    if fovDeg>=180 then _fovFullScreen=true; return vpX*0.5,vpY*0.5 end
    _fovFullScreen=false
    local safeFov=min(fovDeg,179.9)
    local tanHalfFov=tan(rad(safeFov*0.5))
    local radiusY=tanHalfFov/_tanHalfCamFOV*(vpY*0.5)
    local radiusX=radiusY*(vpX/vpY)
    -- Clamp ao viewport: acima do FOV da câmera o círculo ultrapassa a tela
    -- O aimbot continua buscando na área correta, o visual só para na borda
    local maxRY=vpY*0.499; local maxRX=vpX*0.499
    if radiusY>maxRY or radiusX>maxRX then
        _fovFullScreen=true; return vpX*0.5,vpY*0.5
    end
    return radiusX,radiusY
end

function Lib.animFov(targetColor,duration)
