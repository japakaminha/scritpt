local function getFinalAimPosition(aimPart,state,camPos)
    if not aimPart or not aimPart.Parent then return nil end
    local base=aimPart.Position; local dx=base.X-camPos.X; local dy=base.Y-camPos.Y; local dz=base.Z-camPos.Z
    local dist2=dx*dx+dy*dy+dz*dz; if dist2<MIN_TARGET_DIST2 then return nil end
    if Config.PredictionEnabled and state and state.isMoving then
        local vel=state.velocity; local vx,vy,vz=vel.X,vel.Y,vel.Z; local vMag2=vx*vx+vy*vy+vz*vz
        if vMag2>1 then
            local ping=Config.LagCompensation and _getCachedPing() or 0; local dist=sqrt(dist2)
            local bulletTime=(Config.BulletSpeed>0) and (dist/Config.BulletSpeed) or 0
            local tPred=ping+bulletTime+0.016
            -- AIM-FIX-1: loop iterativo refinado — cada iteração recalcula tPred com a posição predita anterior
            -- Isso converge para o tempo de voo correto (ao invés de usar sempre a distância original)
            for _=1,2 do
                local ox,oy,oz=vx*tPred,vy*tPred,vz*tPred
                local maxPred=state.speed*tPred*MAX_PREDICTION_VEL
                local omag2=ox*ox+oy*oy+oz*oz
                if omag2>maxPred*maxPred then local s=maxPred/sqrt(omag2); ox=ox*s; oy=oy*s; oz=oz*s end
                if not state.isAirborne or state.inVehicle then oy=0 end
                local predX=base.X+ox; local predY=base.Y+oy; local predZ=base.Z+oz
                local ndx=predX-camPos.X; local ndy=predY-camPos.Y; local ndz=predZ-camPos.Z
                local newDist=sqrt(ndx*ndx+ndy*ndy+ndz*ndz)
                bulletTime=(Config.BulletSpeed>0) and (newDist/Config.BulletSpeed) or 0
                tPred=ping+bulletTime+0.016
            end
