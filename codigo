    local panicBind = Config.Keybinds.Panic
    if panicBind and _inputMatch(input, panicBind) then
        if panicHoldStart then
            local holdTime = tick() - panicHoldStart
            if holdTime >= 1.5 then
                Config.AimbotEnabled = false
