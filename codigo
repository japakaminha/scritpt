function Lib._getHP(hpPct)
    if hpPct >= 0.5 then
        local t = (hpPct - 0.5) * 2
        return Color3.new(t, 1, 0)
    else
        local t = hpPct * 2
        return Color3.new(1, t, 0)
    end
end

local function _updateESPBox(player, box)
    if not player or not box or box == _dummySingleton then return end
    
    local char = player.Character
    if not char then return end
    
    local cc = _getCharCache(char)
    local hum = cc and cc.hum
    if not hum or hum.Health <= 0 then return end
    
    local root = cc and cc.root
    if not root then return end
    
    local headX, headY, headZ, headOnScreen = getVPPoint(cc.Head)
    local rootX, rootY, rootZ, rootOnScreen = getVPPoint(root)
    
    if not (headOnScreen and rootOnScreen) or headZ < 0 or rootZ < 0 then
        box.Visible = false
        return
    end
    
    local topY = min(headY, rootY)
    local bottomY = max(headY, rootY)
    local boxHeight = bottomY - topY
    local boxWidth = boxHeight * 0.5
    
    local boxLeft = (headX + rootX) / 2 - boxWidth / 2
    local boxTop = topY
    
    local isVisible = false
    local slot = _visCache[char]
    if slot then
        isVisible = slot.vis
    end
    
    local boxColor = isVisible and Config.ESPColor or Config.ESPWallColor
    
    if Config.ShowWhitelistESP and Config.Whitelist[player.UserId] then
        boxColor = _C_WL_ESP
    end
    
    box.Position = Vector2.new(boxLeft, boxTop)
    box.Size = Vector2.new(boxWidth, boxHeight)
    box.Color = boxColor
    box.Visible = Config.ESPEnabled
end

local function _updateESPSkeleton(player, bones)
    if not player or not bones or #bones == 0 then return end
    
    local char = player.Character
    if not char then return end
    
    local cc = _getCharCache(char)
    local hum = cc and cc.hum
    if not hum or hum.Health <= 0 then return end
    
    local boneCache = _boneCache[char]
    if not boneCache then return end
    
    local BONE_CONNECTIONS = {
        {"Head", "UpperTorso"},
        {"UpperTorso", "LeftUpperArm"},
        {"LeftUpperArm", "LeftLowerArm"},
        {"LeftLowerArm", "LeftHand"},
        {"UpperTorso", "RightUpperArm"},
        {"RightUpperArm", "RightLowerArm"},
        {"RightLowerArm", "RightHand"},
        {"UpperTorso", "LowerTorso"},
        {"LowerTorso", "LeftUpperLeg"},
        {"LeftUpperLeg", "LeftLowerLeg"},
        {"LeftLowerLeg", "LeftFoot"},
        {"LowerTorso", "RightUpperLeg"},
        {"RightUpperLeg", "RightLowerLeg"},
        {"RightLowerLeg", "RightFoot"}
    }
    
    local idx = 1
    for _, conn in ipairs(BONE_CONNECTIONS) do
        if idx > #bones then break end
        
        local from = conn[1]
        local to = conn[2]
        
        local fromPart = boneCache[from]
        local toPart = boneCache[to]
        
        if fromPart and toPart then
            local fx, fy, fz, fon = getVPPoint(fromPart)
            local tx, ty, tz, ton = getVPPoint(toPart)
            
            if fon and ton and fz > 0 and tz > 0 then
                local slot = _visCache[char]
                local isVis = slot and slot.vis
                
                local color = isVis and Config.ESPColor or Config.ESPWallColor
                
                bones[idx].From = Vector2.new(fx, fy)
                bones[idx].To = Vector2.new(tx, ty)
                bones[idx].Color = color
                bones[idx].Visible = Config.SkeletonEnabled
            else
                bones[idx].Visible = false
            end
        else
            bones[idx].Visible = false
        end
        
        idx = idx + 1
    end
    
    for i = idx, #bones do
        bones[i].Visible = false
    end
end

