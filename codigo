    end
    
    local espBind = Config.Keybinds.ESPKey
    if espBind and _inputMatch(input, espBind) then
        Config.ESPEnabled = not Config.ESPEnabled
        notify("ESP: " .. (Config.ESPEnabled and "ON" or "OFF"), 
            Config.ESPEnabled and "success" or "info")
    end
    
    local releaseBind = Config.Keybinds.ReleaseLock
    if releaseBind and _inputMatch(input, releaseBind) then
        bestTarget = nil
        bestAimPart = nil
        bestTargetRoot = nil
        aimState = AIM_STATE_NONE
        notify("ðŸ”“ Lock liberado", "info", 1)
    end
    
    local flickBind = Config.Keybinds.FlickKey
    if Config.FlickEnabled and flickBind and _inputMatch(input, flickBind) then
        _flickStart()
    end
    
    local peekBind = Config.Keybinds.PeekKey
    if Config.AutoPeekEnabled and peekBind and _inputMatch(input, peekBind) then
        if _peekState == "idle" then
            _peekState = "peeking"
        end
    end
    
    local panicBind = Config.Keybinds.Panic
    if panicBind and _inputMatch(input, panicBind) then
        panicHoldStart = tick()
    end
end)

Lib.Connections.InputEnded = UserInputService.InputEnded:Connect(function(input, gameProcessed)
    local aimBind = Config.Keybinds.AimbotKey
    if aimBind and _inputMatch(input, aimBind) then
        if Config.AimbotMode == "Hold" and isHoldingAim then
            isHoldingAim = false
