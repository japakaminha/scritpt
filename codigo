local function _computeInVehicle(root, char)
    if not root:FindFirstChildOfClass("Weld") and not root:FindFirstChildOfClass("WeldConstraint") then
        return false
    end
    
    for _, j in ipairs(root:GetChildren()) do
        if j:IsA("Weld") or j:IsA("WeldConstraint") then
            local p0 = j.Part0
            local p1 = j.Part1
            local other = (p0 == root) and p1 or p0
            
            if other and not char:IsAncestorOf(other) then
                return true
            end
        end
    end
    return false
end

local function _hookVehicleEvents(char, root)
    local old = _inVehicleEventConns[char]
    if old then
        pcall(function() old[1]:Disconnect() end)
        pcall(function() old[2]:Disconnect() end)
    end
    
    local function invalidate()
        _inVehicleCache[char] = nil
    end
    
    _inVehicleEventConns[char] = {
        root.ChildAdded:Connect(invalidate),
        root.ChildRemoved:Connect(invalidate)
    }
    
    local player = _charToPlayer[char]
    if player then
        _playerVehicleChar[player] = char
    end
end

local function isInVehicle(char)
    local cached = _inVehicleCache[char]
    if cached ~= nil then
        return cached
    end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then
        _inVehicleCache[char] = false
        return false
    end
    
    local result = _computeInVehicle(root, char)
    _inVehicleCache[char] = result
    _hookVehicleEvents(char, root)
    return result
end

