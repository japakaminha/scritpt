            TweenService:Create(fr,TweenInfo.new(0.2,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Size=UDim2.new(1,0,0,44)}):Play()
            task.delay(item.duration,function()
                activeNotifCount=max(0,activeNotifCount-1)
                if not fr or not fr.Parent then return end
                TweenService:Create(fr,TweenInfo.new(0.25),{Size=UDim2.new(1,0,0,0),BackgroundTransparency=1}):Play()
