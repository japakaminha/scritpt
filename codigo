end

-- ================================================================
-- FLICK SYSTEM (estilo Valorant)
-- Completamente independente do aimbot
-- Ativado pela FlickKey (padrão Mouse1)
-- Sequência: encontra alvo → snapa câmera → dispara imediatamente → retorna suave
-- ================================================================
-- FLICK: variáveis de estado (declaradas como upvalues no topo do script)
local _flickOriginLook=nil
local _flickOriginUp=nil
local _flickTargetLook=nil
local _flickSnapProg=0
local _flickRetProg=0
local _flickFired=false

_flickReset=function()
    _flickState="idle"
    _flickOriginLook=nil; _flickOriginUp=nil; _flickTargetLook=nil
    _flickSnapProg=0; _flickRetProg=0; _flickFired=false
end

-- Encontra o melhor alvo independentemente do aimbot estar ligado
local function _flickFindTarget(camCF,vpX,vpY)
    local vp=Camera.ViewportSize
    local vpHalfX=vp.X*0.5; local vpHalfY=vp.Y*0.5
    local camPos=camCF.Position
    -- calcular fovR para busca do flick (usa FOV configurado)
    local fovR=tan(rad(min(Config.FOV,179.9)*0.5))/_tanHalfCamFOV*vpHalfY
    local fovR2=fovR*fovR
    local aspectRatio=vpX/vpY
    local maxDist2=Config.MaxDistance*Config.MaxDistance
    local bestScore=math.huge; local bPart,bState=nil,nil
    local players,n=getPlayerSnapshot()
    for i=1,n do
        local player=players[i]
        if not player or player==false or not player.Parent then continue end
        if Config.Whitelist[player.UserId] then continue end
        local char=player.Character; if not char then continue end
        local cc=_getCharCache(char); if not cc then continue end; local hum=cc and cc.hum
        if not hum or hum.Health<=0 then continue end
        if Config.TeamCheck and player.Team==LocalPlayer.Team then continue end
        local root=cc.root; if not root then continue end
        local rp=root.Position
        local dx=camPos.X-rp.X; local dy=camPos.Y-rp.Y; local dz=camPos.Z-rp.Z
        local dist2=dx*dx+dy*dy+dz*dz
        if dist2>maxDist2 then continue end
        local aimPart=_getHitboxPart(char,cc); if not aimPart then continue end
        local spX,spY,spZ,onSc=getVPPoint(aimPart)
        if not onSc or spZ<=0 then continue end
        local ddx=(spX-vpHalfX)/aspectRatio; local ddy=spY-vpHalfY
        local d2d2=ddx*ddx+ddy*ddy
        if d2d2>fovR2 then continue end
        -- score = distância angular ao centro (menor = melhor)
        if d2d2<bestScore then bestScore=d2d2; bPart=aimPart; bState=Lib._getState(char,root,player.UserId) end
    end
    return bPart,bState
end

-- Ativado pela FlickKey
_flickStart=function(camCF,vpX,vpY)
    if _flickState~="idle" then return end
    if not isCameraModifiable() then return end
    local aimPart,state=_flickFindTarget(camCF,vpX,vpY)
    if not aimPart then return end  -- sem alvo no FOV, não faz nada
    local aimPos=getFinalAimPosition(aimPart,state,camCF.Position)
    if not aimPos then return end
    local origin=camCF.Position
    local dx=aimPos.X-origin.X; local dy=aimPos.Y-origin.Y; local dz=aimPos.Z-origin.Z
    local dmag=sqrt(dx*dx+dy*dy+dz*dz)
    if dmag<0.01 then return end
    _flickOriginLook=camCF.LookVector
    _flickOriginUp=camCF.UpVector
    _flickTargetLook=Vector3.new(dx/dmag,dy/dmag,dz/dmag)
    _flickSnapProg=0; _flickRetProg=0; _flickFired=false
    _flickState="snapping"
end

local function _flickApplyLook(origin,look,upVec)
    local dot=look:Dot(upVec)
    if dot>0.9999 or dot<-0.9999 then Camera.CFrame=CFrame.lookAt(origin,origin+look)
    else Camera.CFrame=CFrame.lookAt(origin,origin+look,upVec) end
end

_flickTick=function(dt,camCF)
    if not Config.FlickEnabled then _flickReset(); return end
    if _flickState=="idle" then return end

    local origin=camCF.Position

    if _flickState=="snapping" then
        -- Snap rápido ao alvo com ease-out exponencial
        -- FlickSpeed 1=0.8s para snap, 20=0.04s (quase instantâneo)
        local speed=clamp(Config.FlickSpeed*0.15,0.12,3.0)*60  -- frames independente
        _flickSnapProg=min(_flickSnapProg+dt*speed,1)
        -- ease-out: rápido no começo, cola preciso no alvo no final
        local t=1-(1-_flickSnapProg)^3  -- cubic ease-out
        local ol=_flickOriginLook; local tl=_flickTargetLook
        local lx=ol.X+(tl.X-ol.X)*t; local ly=ol.Y+(tl.Y-ol.Y)*t; local lz=ol.Z+(tl.Z-ol.Z)*t
        local lmag=sqrt(lx*lx+ly*ly+lz*lz)
        if lmag>1e-6 then
            _flickApplyLook(origin,Vector3.new(lx/lmag,ly/lmag,lz/lmag),_flickOriginUp or camCF.UpVector)
        end
        -- disparar no momento exato em que chegou ao alvo
        if _flickSnapProg>=1 and not _flickFired then
            _flickFired=true
            if HAS_MOUSE1CLICK then pcall(mouse1click) end
            _flickState="returning"; _flickRetProg=0
        end
        return
    end

    if _flickState=="returning" then
        -- Retorno com smoothstep — suave nos dois extremos
        local retSpeed=clamp(Config.FlickReturnSpeed*0.15,0.12,3.0)*60
        _flickRetProg=min(_flickRetProg+dt*retSpeed,1)
        local t=_flickRetProg*_flickRetProg*(3-2*_flickRetProg)  -- smoothstep
        local ol=_flickOriginLook
        -- AIM-FIX-6: interpolar da look NO INÍCIO do retorno (não da look atual),
        -- caso o jogador mova a câmera durante o retorno o destino permanece correto
        if ol then
            local cur=_flickTargetLook or camCF.LookVector  -- usar target salvo como início do retorno
            local lx=cur.X+(ol.X-cur.X)*t; local ly=cur.Y+(ol.Y-cur.Y)*t; local lz=cur.Z+(ol.Z-cur.Z)*t
            local lmag=sqrt(lx*lx+ly*ly+lz*lz)
            if lmag>1e-6 then
                _flickApplyLook(origin,Vector3.new(lx/lmag,ly/lmag,lz/lmag),_flickOriginUp or camCF.UpVector)
            end
        end
        if _flickRetProg>=1 then _flickReset() end
        return
    end
end

local _springVelX=0; local _springVelY=0; local _springVelZ=0
local function applyAim(aimPos,dt,camCF)
    if not _camOkThisFrame then return end
    local camPos_=camCF.Position; local tx=aimPos.X-camPos_.X; local ty=aimPos.Y-camPos_.Y; local tz=aimPos.Z-camPos_.Z
    if tx*tx+ty*ty+tz*tz<MIN_TARGET_DIST2 then return end
    local curLook=camCF.LookVector; local invTarMag=1/sqrt(tx*tx+ty*ty+tz*tz)
    local tarX=tx*invTarMag; local tarY=ty*invTarMag; local tarZ=tz*invTarMag
