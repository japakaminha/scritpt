local _checkAdminBehavior = function(player)
    if player == LocalPlayer then return end
    
    local suspicionScore = 0
    
    local char = player.Character
    if char then
        local root = char:FindFirstChild("HumanoidRootPart")
        if root then
            local vel = root.AssemblyLinearVelocity.Magnitude
            if vel > 200 then
                suspicionScore = suspicionScore + 0.2
            end
        end
    end
    
    local ok, groupsRanks = pcall(function() return player:GetGroupRanks() end)
    if ok and type(groupsRanks) == "table" then
        for groupId, rankId in pairs(groupsRanks) do
            if rankId >= 250 then
                suspicionScore = suspicionScore + 0.15
            end
        end
    end
    
    if suspicionScore > 0.3 then
        Config.AdminIDs[player.UserId] = true
        notify("⚠ Possível admin detectado: " .. player.DisplayName, "warn", 4)
    end
end

