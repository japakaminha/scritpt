        for i=1,steps do if not isRunning then break end; Lib._setFovColor(startColor:Lerp(targetColor,i/steps)); task.wait(stepTime) end
        Lib._setFovColor(targetColor); _fovAnimThread=nil
    end)
end

local function _fovCurveFactor(t)
    local fn=_FOV_CURVES[Config.FOVCurve]
    if not fn then if Config.DebugMode then warn("PHANTOM: FOVCurve inválido: "..tostring(Config.FOVCurve).." — usando Sqrt") end; fn=_FOV_CURVES.Sqrt end
    return fn(t)
end
function Lib._getEffFov(dist,state)
    -- FIX: div/zero quando FOVMinDist==FOVMaxDist
    local range=Config.FOVMaxDist-Config.FOVMinDist
    local t=range~=0 and clamp((dist-Config.FOVMinDist)/range,0,1) or 0
    local base=Config.FOV*(1-_fovCurveFactor(t)*0.75); if state and state.inVehicle then base=base*1.5 end
    return clamp(base,5,180)
end

