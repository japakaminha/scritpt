Lib.Connections.RCSTick=RunService.Heartbeat:Connect(function(dt)
    if not Config.DynRCSEnabled or not isCameraModifiable() then _rcsLookPrev=nil; return end
    local camCF=Camera.CFrame
    local curLook=camCF.LookVector
    if not _rcsFiring then _rcsLookPrev=curLook; return end

    local maxSamples=Config.DynRCSMaxSamples
    local strength=Config.DynRCSStrength*0.01

    -- FASE 1: APRENDIZADO — medir desvio real ANTES de qualquer compensação
    if _rcsLookPrev then
        local dx=curLook.X-_rcsLookPrev.X
        local dy=curLook.Y-_rcsLookPrev.Y
        local dz=curLook.Z-_rcsLookPrev.Z
        local dMag=sqrt(dx*dx+dy*dy+dz*dz)
        if dMag>0.0005 then
            _rcsSampleIdx=(_rcsSampleIdx%maxSamples)+1
            _rcsPattern[_rcsSampleIdx]={dx=dx,dy=dy,dz=dz}
            if #_rcsPattern>=3 then _rcsLearned=true end
            _rcsFrameCount=_rcsFrameCount+1
        end
    end

    -- FIX: salvar curLook ANTES da compensação — evita medir o próprio correção como recoil
    _rcsLookPrev=curLook

    -- FASE 2: APLICAÇÃO — só aplica após ter padrão aprendido E pelo menos 1 disparo de diferença
    -- Usa o sample da rodada ANTERIOR (não a atual) para não compensar o que ainda não aprendeu
    if _rcsLearned and _rcsFrameCount>1 then
        -- applyIdx aponta para 1 amostra atrás do índice atual (padrão da rodada anterior)
        local applyIdx=((_rcsApplyIdx)%maxSamples)+1
