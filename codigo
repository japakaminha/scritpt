    local hrp=char:FindFirstChild("HumanoidRootPart"); if not hrp then return end
    if not isCameraModifiable() then return end
    -- determinar direção do peek: lateral em relação ao alvo (ou câmera)
    local camCF=Camera.CFrame; local origin=hrp.Position
    local peekDir
    if bestTarget and bestTargetRoot then
        -- perpendicular ao vetor câmera→alvo, no plano horizontal
        local toTarget=(bestTargetRoot.Position-origin)*Vector3.new(1,0,1)
        local tMag=toTarget.Magnitude
        if tMag>0.1 then
            local fwd=toTarget/tMag
