    if not HAS_DRAWING then return end
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local char = player.Character
            local cc = _getCharCache(char)
            
            if cc and cc.hum and cc.hum.Health > 0 then
                if Config.ESPEnabled then
                    local box = _activeESP[player]
                    if not box then
                        box = poolGet(_poolESP, "Square")
                        _activeESP[player] = box
                    end
                    _updateESPBox(player, box)
