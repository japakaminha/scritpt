    local state=Lib._getState(char,root,player.UserId); return score,char,aimPart,root,state
end

local function findBestTarget(camCF,vpX,vpY)
    local vpHalfX=vpX*0.5; local vpHalfY=vpY*0.5; local camPos_=camCF.Position; local nowTick=_frameTick
    local fovForCalc=Config.FOV
    -- AIM-FIX-4: verificar bestTargetRoot.Parent antes de acessar .Position
    if bestTarget and bestTargetRoot and bestTargetRoot.Parent then
        local _bx=camPos_.X-bestTargetRoot.Position.X; local _by=camPos_.Y-bestTargetRoot.Position.Y; local _bz=camPos_.Z-bestTargetRoot.Position.Z
        fovForCalc=Lib._getEffFov(sqrt(_bx*_bx+_by*_by+_bz*_bz),bestTargetState)
    end
    if fovForCalc~=_lastAimFov or vpY~=_lastAimVpY then _lastAimFov=fovForCalc; _lastAimVpY=vpY; _cachedAimFovR=tan(rad(fovForCalc*0.5))/_tanHalfCamFOV*vpHalfY; _cachedFovR2=_cachedAimFovR*_cachedAimFovR end
    local fovR=_cachedAimFovR; local fovR2=_cachedFovR2
    if vpX~=_lastAspectVpX or vpY~=_lastAspectVpY then _lastAspectVpX=vpX; _lastAspectVpY=vpY; _cachedAspectRatio=vpX/vpY end
    if Config.MaxDistance~=_lastMaxDist then _lastMaxDist=Config.MaxDistance; _cachedMaxDist2=Config.MaxDistance*Config.MaxDistance end
    if Config.LockThreshold~=_lastLockThresh or vpY~=_lastThreshVpY then _lastLockThresh=Config.LockThreshold; _lastThreshVpY=vpY; _cachedThreshR=tan(rad(Config.LockThreshold*0.5))/_tanHalfCamFOV*vpHalfY end
    local aspectRatio=_cachedAspectRatio; local maxDist2=_cachedMaxDist2; local threshR=_cachedThreshR
    local bestScore=huge; local bTarget,bPart,bRoot,bState=nil,nil,nil,nil
    local lockAge=nowTick-_bestTargetLockStart; local inLockMin=bestTarget~=nil and lockAge<Config.LockMinTime
    local players,playerCount=getPlayerSnapshot()
    for i=1,playerCount do
        local player=players[i]
        local score,char,aimPart,root,state=_tryScorePlayer(player,camCF,camPos_,vpHalfX,vpHalfY,fovR2,fovR,maxDist2,threshR,nowTick,aspectRatio,lockAge,inLockMin)
        if score and score<bestScore then bestScore=score; bTarget=char; bPart=aimPart; bRoot=root; bState=state end
    end
    if inLockMin and bTarget==nil then
        local cc=_getCharCache(bestTarget); local hum=cc and cc.hum
        if hum and hum.Health>0 and bestTarget.Parent~=nil and bestAimPart and bestAimPart.Parent then return bestTarget,bestAimPart,bestTargetRoot,bestTargetState end
        _bestTargetLockStart=0; return nil,nil,nil,nil
    end
    if bTarget~=bestTarget then
        _bestTargetLastLoS=nowTick; _bestTargetLockStart=nowTick
        -- FIX: reset spring ao trocar de alvo evita overshooting na direção errada
        _springVelX=0; _springVelY=0; _springVelZ=0
    end
    return bTarget,bPart,bRoot,bState
end

